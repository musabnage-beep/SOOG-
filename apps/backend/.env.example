# ─── App ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=ALDIAFAH
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://aldiafa:aldiafa@localhost:5432/aldiafa?schema=public

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_TTL=2592000

# ─── OTP ────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_LENGTH=6
# Provider: 'console' (dev, logs code) | 'unifonic' | 'twilio'
SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER_ID=ALDIAFAH

# ─── Rate limiting ──────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ─── AWS S3 (product images) ────────────────────────────────────────────────
# Provider: 'local' (dev, writes to ./uploads) | 's3'
STORAGE_PROVIDER=local
AWS_REGION=me-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=aldiafa-product-images
S3_PUBLIC_BASE_URL=https://cdn.aldiafah.example
LOCAL_UPLOAD_DIR=./uploads

# ─── Google Maps ────────────────────────────────────────────────────────────
# Provider: 'dev' (haversine only, no external calls) | 'google'
MAPS_PROVIDER=dev
GOOGLE_MAPS_API_KEY=

# ─── Firebase Cloud Messaging (push) ────────────────────────────────────────
# Provider: 'console' (dev, logs payload) | 'fcm'
PUSH_PROVIDER=console
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Newlines in the private key must be escaped as \n
FIREBASE_PRIVATE_KEY=

# ─── Email (AWS SES) ────────────────────────────────────────────────────────
# Provider: 'console' (dev, logs email) | 'ses'
MAIL_PROVIDER=console
MAIL_FROM=no-reply@aldiafah.example
SES_REGION=me-central-1

# ─── Seed ───────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@aldiafah.example
SEED_ADMIN_PASSWORD=ChangeMe!2026
SEED_ADMIN_PHONE=+966500000000
