# ───────────────────────────────────────────────────────────────────────────
# ALDIAFAH — EC2 / bare-IP environment template
# Copy: cp infra/.env.ec2.example infra/.env.ec2
# Then fill YOUR_IP and generate secrets (see commands below).
# NEVER commit infra/.env.ec2
# ───────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=aldiafa
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=aldiafa

# ── JWT Secrets — generate with: openssl rand -hex 24 ────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_DIFFERENT

# ── Replace YOUR_IP with the EC2 Elastic IP ──────────────────────────────────
CORS_ORIGINS=http://YOUR_IP:3100,http://YOUR_IP:3200
ADMIN_PUBLIC_API_URL=http://YOUR_IP:3000/api
EMPLOYEE_PUBLIC_API_URL=http://YOUR_IP:3000/api

# ── Seed admin (created automatically on first boot) ─────────────────────────
SEED_ADMIN_EMAIL=admin@aldiafah.com
SEED_ADMIN_PASSWORD=Admin@2026!
SEED_ADMIN_PHONE=+966500000000

# ── Providers — console/local = no external keys needed ─────────────────────
STORAGE_PROVIDER=local
MAPS_PROVIDER=dev
SMS_PROVIDER=console
PUSH_PROVIDER=console
MAIL_PROVIDER=console
PAYMENT_PROVIDER=console

# ── Optional — fill when switching providers ──────────────────────────────────
AWS_REGION=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GOOGLE_MAPS_API_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=
PAYMENT_CALLBACK_URL=
