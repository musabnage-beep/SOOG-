# ───────────────────────────────────────────────────────────────────────────
# ALDIAFAH production stack — infra/docker-compose.prod.yml
# Copy to infra/.env and fill real values. NEVER commit infra/.env.
# ───────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=aldiafa
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=aldiafa

# ── Backend secrets (min 16 chars each) ─────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars

# Comma-separated allowed origins for the API (your dashboard domains)
CORS_ORIGINS=https://admin.aldiafah.com,https://staff.aldiafah.com

# Seed admin (created on first migrate/seed)
SEED_ADMIN_EMAIL=admin@aldiafah.com
SEED_ADMIN_PASSWORD=ChangeMe!1
SEED_ADMIN_PHONE=+966500000000

# ── Provider selection: dev default | <real>  ───────────────────────────────
# local = store uploads on disk volume; s3 = AWS S3
STORAGE_PROVIDER=local
MAPS_PROVIDER=dev          # google
SMS_PROVIDER=console       # unifonic | twilio
PUSH_PROVIDER=console      # fcm
MAIL_PROVIDER=console      # ses

# ── AWS (only when STORAGE_PROVIDER=s3 / MAIL_PROVIDER=ses) ───────────────────
AWS_REGION=me-central-1
S3_BUCKET=aldiafa-uploads
S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Google Maps (only when MAPS_PROVIDER=google) ─────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Payments (console default | moyasar) ─────────────────────────────────────
PAYMENT_PROVIDER=console
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=
PAYMENT_CALLBACK_URL=https://api.aldiafah.com/api/payments/callback

# ── Dashboard build-time API URLs (baked into the bundles) ───────────────────
ADMIN_PUBLIC_API_URL=https://api.aldiafah.com/api
EMPLOYEE_PUBLIC_API_URL=https://api.aldiafah.com/api
